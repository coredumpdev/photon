{
  "name": "@photonviz/core",
  "version": "0.1.0",
  "description": "WebGL2 scientific plotting core — framework-agnostic",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["webgl2", "webgl", "plot", "plotting", "chart", "scientific", "visualization", "photon"],
  "license": "MIT"
}
