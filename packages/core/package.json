{
  "name": "@photonviz/core",
  "version": "0.2.0",
  "description": "WebGL2 scientific plotting core \u2014 framework-agnostic",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "webgl2",
    "webgl",
    "plot",
    "plotting",
    "chart",
    "scientific",
    "visualization",
    "photon"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coredumpdev/photon.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/coredumpdev/photon#readme",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
