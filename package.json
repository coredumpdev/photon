{
  "name": "photonviz-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Photon — WebGL2 scientific plotting for the web",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "dev": "pnpm -r --parallel --filter \"./packages/*\" dev",
    "typecheck": "pnpm -r --filter \"./packages/*\" exec tsc --noEmit",
    "test": "vitest run",
    "example": "vite examples/vanilla",
    "example:react": "pnpm --filter @photonviz/example-react dev",
    "example:vue": "pnpm --filter @photonviz/example-vue dev",
    "example:svelte": "pnpm --filter @photonviz/example-svelte dev"
  },
  "devDependencies": {
    "playwright": "^1.61.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@9.15.0"
}
